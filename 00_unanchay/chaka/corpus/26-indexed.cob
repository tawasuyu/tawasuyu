IDENTIFICATION DIVISION.
PROGRAM-ID. INDEXADO.
ENVIRONMENT DIVISION.
INPUT-OUTPUT SECTION.
FILE-CONTROL.
    SELECT CLI ASSIGN TO '/tmp/chaka-corpus-26.idx'
        ORGANIZATION IS INDEXED
        ACCESS MODE IS DYNAMIC
        RECORD KEY IS CLI-ID.
DATA DIVISION.
FILE SECTION.
FD CLI.
01 REG-CLI.
   05 CLI-ID  PIC X(3).
   05 CLI-NOM PIC X(8).
WORKING-STORAGE SECTION.
01 WS-FIN PIC X VALUE 'N'.
   88 FIN VALUE 'Y'.
PROCEDURE DIVISION.
MAIN.
    OPEN OUTPUT CLI.
    MOVE 'C03' TO CLI-ID.
    MOVE 'CARLOS' TO CLI-NOM.
    WRITE REG-CLI.
    MOVE 'A01' TO CLI-ID.
    MOVE 'ANA' TO CLI-NOM.
    WRITE REG-CLI.
    MOVE 'B02' TO CLI-ID.
    MOVE 'BETO' TO CLI-NOM.
    WRITE REG-CLI.
    MOVE 'A01' TO CLI-ID.
    MOVE 'OTRA' TO CLI-NOM.
    WRITE REG-CLI
        INVALID KEY DISPLAY 'DUP ' CLI-ID
        NOT INVALID KEY DISPLAY 'NEW ' CLI-ID
    END-WRITE.
    CLOSE CLI.
    OPEN I-O CLI.
    MOVE 'B02' TO CLI-ID.
    READ CLI
        INVALID KEY DISPLAY 'NOHAY'
        NOT INVALID KEY DISPLAY 'LEIDO ' CLI-NOM
    END-READ.
    MOVE 'Z99' TO CLI-ID.
    READ CLI
        INVALID KEY DISPLAY 'NOHAY ' CLI-ID
        NOT INVALID KEY DISPLAY 'LEIDO ' CLI-NOM
    END-READ.
    MOVE 'C03' TO CLI-ID.
    MOVE 'CARLA' TO CLI-NOM.
    REWRITE REG-CLI
        INVALID KEY DISPLAY 'RWNO'
        NOT INVALID KEY DISPLAY 'RWOK'
    END-REWRITE.
    MOVE 'A01' TO CLI-ID.
    DELETE CLI
        INVALID KEY DISPLAY 'DELNO'
        NOT INVALID KEY DISPLAY 'DELOK'
    END-DELETE.
    MOVE 'A00' TO CLI-ID.
    START CLI KEY >= CLI-ID
        INVALID KEY DISPLAY 'VACIO'
    END-START.
    PERFORM UNTIL FIN
        READ CLI NEXT
            AT END SET FIN TO TRUE
            NOT AT END DISPLAY CLI-ID ' ' CLI-NOM
        END-READ
    END-PERFORM.
    CLOSE CLI.
    STOP RUN.
