{
  "module": "facturacion",
  "schemas": ["../accounting/schema.ncl", "schema.ncl"],
  "morphisms": [
    {
      "name": "emitir_factura",
      "inputs": [
        { "role": "clientes_cta", "entity": "Cuenta" },
        { "role": "ventas_cta", "entity": "Cuenta" },
        { "role": "iva_cta", "entity": "Cuenta" }
      ],
      "reads": [
        "clientes_cta.saldo", "clientes_cta.moneda",
        "ventas_cta.saldo", "ventas_cta.moneda",
        "iva_cta.saldo", "iva_cta.moneda"
      ],
      "writes": ["clientes_cta.saldo", "ventas_cta.saldo", "iva_cta.saldo", "Factura"],
      "invariants": {
        "conserve": [{ "entity": "Cuenta", "field": "saldo", "group_by": "moneda" }]
      },
      "script": "morphisms/emitir_factura.rhai"
    },
    {
      "name": "facturar",
      "inputs": [
        { "role": "clientes_cta", "entity": "Cuenta" },
        { "role": "ventas_cta", "entity": "Cuenta" },
        { "role": "iva_cta", "entity": "Cuenta" },
        { "role": "secuencia", "entity": "Secuencia" }
      ],
      "reads": [
        "clientes_cta.saldo", "clientes_cta.moneda",
        "ventas_cta.saldo", "ventas_cta.moneda",
        "iva_cta.saldo", "iva_cta.moneda",
        "secuencia.prefijo", "secuencia.proximo"
      ],
      "writes": ["clientes_cta.saldo", "ventas_cta.saldo", "iva_cta.saldo", "secuencia.proximo", "Factura", "LineaFactura"],
      "invariants": {
        "conserve": [{ "entity": "Cuenta", "field": "saldo", "group_by": "moneda" }]
      },
      "script": "morphisms/facturar.rhai"
    },
    {
      "name": "cobrar",
      "inputs": [
        { "role": "banco_cta", "entity": "Cuenta" },
        { "role": "clientes_cta", "entity": "Cuenta" },
        { "role": "factura", "entity": "Factura" }
      ],
      "reads": [
        "banco_cta.saldo", "banco_cta.moneda",
        "clientes_cta.saldo", "clientes_cta.moneda",
        "factura.total", "factura.moneda", "factura.estado"
      ],
      "writes": ["banco_cta.saldo", "clientes_cta.saldo", "factura.estado", "Cobro"],
      "invariants": {
        "conserve": [{ "entity": "Cuenta", "field": "saldo", "group_by": "moneda" }]
      },
      "script": "morphisms/cobrar.rhai"
    }
  ]
}
