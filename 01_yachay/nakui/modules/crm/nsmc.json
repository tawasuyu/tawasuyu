{
  "module": "crm",
  "schemas": ["../accounting/schema.ncl", "../facturacion/schema.ncl", "schema.ncl"],
  "morphisms": [
    {
      "name": "registrar_cliente",
      "inputs": [],
      "reads": [],
      "writes": ["Cliente"],
      "script": "scripts/registrar_cliente.rhai"
    },
    {
      "name": "abrir_oportunidad",
      "inputs": [{ "role": "cliente", "entity": "Cliente" }],
      "reads": [],
      "writes": ["Oportunidad"],
      "script": "scripts/abrir_oportunidad.rhai"
    },
    {
      "name": "mover_oportunidad",
      "inputs": [{ "role": "oportunidad", "entity": "Oportunidad" }],
      "reads": ["oportunidad.etapa"],
      "writes": ["oportunidad.etapa"],
      "script": "scripts/mover_oportunidad.rhai"
    },
    {
      "name": "marcar_perdida",
      "inputs": [{ "role": "oportunidad", "entity": "Oportunidad" }],
      "reads": ["oportunidad.etapa"],
      "writes": ["oportunidad.etapa", "oportunidad.motivo"],
      "script": "scripts/marcar_perdida.rhai"
    },
    {
      "name": "registrar_interaccion",
      "inputs": [{ "role": "cliente", "entity": "Cliente" }],
      "reads": [],
      "writes": ["Interaccion"],
      "script": "scripts/registrar_interaccion.rhai"
    },
    {
      "name": "cotizar_oportunidad",
      "inputs": [{ "role": "oportunidad", "entity": "Oportunidad" }],
      "reads": [
        "oportunidad.etapa", "oportunidad.cliente_id",
        "oportunidad.titulo", "oportunidad.monto", "oportunidad.currency"
      ],
      "writes": ["Cotizacion"],
      "script": "scripts/cotizar_oportunidad.rhai"
    },
    {
      "name": "facturar_cotizacion",
      "inputs": [
        { "role": "cotizacion", "entity": "Cotizacion" },
        { "role": "clientes_cta", "entity": "Cuenta" },
        { "role": "ventas_cta", "entity": "Cuenta" },
        { "role": "iva_cta", "entity": "Cuenta" }
      ],
      "reads": [
        "cotizacion.estado", "cotizacion.monto", "cotizacion.currency", "cotizacion.cliente_id",
        "clientes_cta.saldo", "clientes_cta.moneda",
        "ventas_cta.saldo", "ventas_cta.moneda",
        "iva_cta.saldo", "iva_cta.moneda"
      ],
      "writes": ["clientes_cta.saldo", "ventas_cta.saldo", "iva_cta.saldo", "cotizacion.estado", "Factura"],
      "invariants": {
        "conserve": [{ "entity": "Cuenta", "field": "saldo", "group_by": "moneda" }]
      },
      "script": "scripts/facturar_cotizacion.rhai"
    },
    {
      "name": "cobrar",
      "inputs": [
        { "role": "banco_cta", "entity": "Cuenta" },
        { "role": "clientes_cta", "entity": "Cuenta" },
        { "role": "factura", "entity": "Factura" }
      ],
      "reads": [
        "banco_cta.saldo", "banco_cta.moneda",
        "clientes_cta.saldo", "clientes_cta.moneda",
        "factura.total", "factura.moneda", "factura.estado"
      ],
      "writes": ["banco_cta.saldo", "clientes_cta.saldo", "factura.estado", "Cobro"],
      "invariants": {
        "conserve": [{ "entity": "Cuenta", "field": "saldo", "group_by": "moneda" }]
      },
      "script": "../facturacion/morphisms/cobrar.rhai"
    }
  ]
}
