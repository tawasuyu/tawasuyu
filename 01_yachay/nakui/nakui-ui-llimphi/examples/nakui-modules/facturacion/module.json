{
  "id": "facturacion",
  "label": "Facturación",
  "description": "Emisión de facturas de venta que ASIENTAN en el libro de contabilidad: el form liga las tres cuentas de control (Clientes/Ventas/IVA), calcula el IVA y postea el asiento balanceado. Comparte el plan de cuentas sembrado por Contabilidad. Importes en unidades enteras de moneda.",
  "nakui_module_dir": "nakui",
  "entities": [
    { "name": "Cuenta", "label": "Cuenta", "fields": [] },
    { "name": "Factura", "label": "Factura", "fields": [] },
    { "name": "LineaFactura", "label": "Línea de factura", "fields": [] }
  ],
  "menu": [
    { "label": "Tablero", "view": "tablero" },
    { "label": "Facturas", "view": "facturas_list" },
    { "label": "Facturar (con líneas)", "view": "facturar_form" },
    { "label": "Emitir (rápida)", "view": "emitir_form" },
    { "label": "Líneas", "view": "lineas_list" },
    { "label": "Libro de morfismos", "view": "libro" }
  ],
  "views": {
    "tablero": {
      "kind": "dashboard",
      "title": "Facturación",
      "subtitle": "Cada factura emitida postea un asiento balanceado (debe Clientes / haber Ventas + IVA). El IVA por pagar se acumula como pasivo.",
      "cards": [
        { "label": "Facturas", "entity": "Factura", "metric": { "kind": "count" } },
        {
          "label": "Facturado (total)",
          "entity": "Factura",
          "metric": { "kind": "sum", "field": "total" },
          "format": { "kind": "currency", "symbol": "$" }
        },
        {
          "label": "Neto gravado",
          "entity": "Factura",
          "metric": { "kind": "sum", "field": "neto" },
          "format": { "kind": "currency", "symbol": "$" }
        },
        {
          "label": "IVA repercutido",
          "entity": "Factura",
          "metric": { "kind": "sum", "field": "impuesto" },
          "format": { "kind": "currency", "symbol": "$" }
        },
        {
          "label": "Ticket promedio",
          "entity": "Factura",
          "metric": { "kind": "avg", "field": "total" },
          "format": { "kind": "currency", "symbol": "$" }
        },
        {
          "label": "Facturado por cliente",
          "entity": "Factura",
          "metric": { "kind": "sum_by", "group": "cliente", "value": "total" },
          "format": { "kind": "currency", "symbol": "$" },
          "chart": "pie",
          "limit": 8
        },
        {
          "label": "Facturado por mes",
          "entity": "Factura",
          "metric": { "kind": "sum_by", "group": "fecha", "value": "total" },
          "format": { "kind": "currency", "symbol": "$" },
          "chart": "columns",
          "bucket": "month"
        }
      ]
    },
    "facturas_list": {
      "kind": "list",
      "title": "Facturas",
      "entity": "Factura",
      "row_detail": "factura_detail",
      "search_in": ["cliente", "estado"],
      "columns": [
        { "field": "fecha", "label": "Fecha" },
        { "field": "cliente", "label": "Cliente" },
        { "field": "neto", "label": "Neto", "format": { "kind": "currency", "symbol": "$" } },
        { "field": "impuesto", "label": "IVA", "format": { "kind": "currency", "symbol": "$" } },
        { "field": "total", "label": "Total", "format": { "kind": "currency", "symbol": "$" } },
        { "field": "estado", "label": "Estado" },
        { "field": "moneda", "label": "Moneda" }
      ]
    },
    "factura_detail": {
      "kind": "detail",
      "title": "Factura",
      "entity": "Factura",
      "fields": [
        { "field": "cliente", "label": "Cliente" },
        { "field": "fecha", "label": "Fecha" },
        { "field": "estado", "label": "Estado" },
        { "field": "neto", "label": "Neto", "format": { "kind": "currency", "symbol": "$" } },
        { "field": "impuesto", "label": "IVA", "format": { "kind": "currency", "symbol": "$" } },
        { "field": "total", "label": "Total", "format": { "kind": "currency", "symbol": "$" } },
        { "field": "moneda", "label": "Moneda" }
      ]
    },
    "emitir_form": {
      "kind": "form",
      "title": "Emitir factura",
      "entity": "Factura",
      "fields": [
        { "name": "cliente", "label": "Cliente", "kind": "text", "required": true },
        { "name": "neto", "label": "Neto (base imponible)", "kind": "number", "required": true, "help": "Importe gravado, sin IVA" },
        { "name": "tasa", "label": "Tasa IVA (%)", "kind": "number", "required": true, "help": "Porcentaje entero, ej. 18" },
        { "name": "clientes_cta", "label": "Cuenta Clientes (CxC)", "kind": "entity_ref", "ref_entity": "Cuenta", "required": true, "help": "Cuenta por cobrar — se debita por el total" },
        { "name": "ventas_cta", "label": "Cuenta Ventas", "kind": "entity_ref", "ref_entity": "Cuenta", "required": true, "help": "Ingreso — se acredita por el neto" },
        { "name": "iva_cta", "label": "Cuenta IVA por pagar", "kind": "entity_ref", "ref_entity": "Cuenta", "required": true, "help": "Pasivo — se acredita por el impuesto" },
        { "name": "fecha", "label": "Fecha", "kind": "date", "required": false, "help": "YYYY-MM-DD" },
        { "name": "factura_id", "label": "Id de factura", "kind": "auto_id" }
      ],
      "on_submit": {
        "kind": "morphism",
        "name": "emitir_factura",
        "inputs": { "clientes_cta": "clientes_cta", "ventas_cta": "ventas_cta", "iva_cta": "iva_cta" },
        "params": ["cliente", "neto", "tasa", "fecha", "factura_id"],
        "next_view": "facturas_list"
      }
    },
    "facturar_form": {
      "kind": "form",
      "title": "Facturar (con líneas)",
      "entity": "Factura",
      "fields": [
        { "name": "cliente", "label": "Cliente", "kind": "text", "required": true },
        {
          "name": "lineas",
          "label": "Líneas (una por renglón: concepto | cantidad | precio)",
          "kind": "array",
          "required": true,
          "help": "Una línea por fila, columnas separadas por «|». Ej: Servicio de diseño | 2 | 500",
          "item_fields": [
            { "name": "id", "label": "Id", "kind": "auto_id" },
            { "name": "concepto", "label": "Concepto", "kind": "text", "required": true },
            { "name": "cantidad", "label": "Cantidad", "kind": "number", "required": true },
            { "name": "precio_unitario", "label": "Precio", "kind": "number", "required": true }
          ]
        },
        { "name": "tasa", "label": "Tasa IVA (%)", "kind": "number", "required": true, "help": "Porcentaje entero, ej. 18" },
        { "name": "clientes_cta", "label": "Cuenta Clientes (CxC)", "kind": "entity_ref", "ref_entity": "Cuenta", "required": true },
        { "name": "ventas_cta", "label": "Cuenta Ventas", "kind": "entity_ref", "ref_entity": "Cuenta", "required": true },
        { "name": "iva_cta", "label": "Cuenta IVA por pagar", "kind": "entity_ref", "ref_entity": "Cuenta", "required": true },
        { "name": "fecha", "label": "Fecha", "kind": "date", "required": false, "help": "YYYY-MM-DD" },
        { "name": "factura_id", "label": "Id de factura", "kind": "auto_id" }
      ],
      "on_submit": {
        "kind": "morphism",
        "name": "facturar",
        "inputs": { "clientes_cta": "clientes_cta", "ventas_cta": "ventas_cta", "iva_cta": "iva_cta" },
        "params": ["cliente", "lineas", "tasa", "fecha", "factura_id"],
        "next_view": "facturas_list"
      }
    },
    "lineas_list": {
      "kind": "list",
      "title": "Líneas de factura",
      "entity": "LineaFactura",
      "search_in": ["concepto"],
      "columns": [
        { "field": "concepto", "label": "Concepto" },
        { "field": "cantidad", "label": "Cantidad" },
        { "field": "precio_unitario", "label": "Precio", "format": { "kind": "currency", "symbol": "$" } },
        { "field": "subtotal", "label": "Subtotal", "format": { "kind": "currency", "symbol": "$" } },
        { "field": "factura_id", "label": "Factura", "ref_entity": "Factura" }
      ]
    },
    "libro": {
      "kind": "graph",
      "title": "Libro de morfismos",
      "subtitle": "Los morfismos `emitir_factura` / `facturar` como nodos: leen/escriben el saldo de las tres cuentas de control y crean la Factura (y sus líneas)."
    }
  }
}
