#!/bin/sh
# mirada-dm — arranca mirada en modo display manager sobre DRM, como lo
# haría un init. Corre como root desde una TTY FÍSICA (Ctrl+Alt+F3, no un
# terminal gráfico ni SSH): el backend DRM toma la consola entera.
#
# Salir del greeter:      Ctrl+Alt+Backspace
# Cambiar de consola:     Ctrl+Alt+F1 … F12
#
# Asiento (seat): por defecto usa seatd —robusto—; lo levanta si hace falta.
# Variables que respeta:
#   LIBSEAT_BACKEND   forzá un backend de libseat (p. ej. «builtin» sin
#                     daemon, o «logind»). Sin esto, libseat autodetecta
#                     (seatd si está, luego logind).
#   XDG_RUNTIME_DIR   dónde publica el socket Wayland (default /run/mirada).
#   MIRADA_GREETER_MOCK="usuario:clave"  salta PAM (probar sin /etc/pam.d/carmen).
set -eu

if [ "$(id -u)" -ne 0 ]; then
    echo "mirada-dm: corré como root —  sudo mirada-dm" >&2
    exit 1
fi

# Seat: si no se forzó un backend y seatd no está corriendo, lo arrancamos.
# libseat lo detecta solo por /run/seatd.sock (más fiable que el builtin,
# que exige colgar de una VT real).
if [ -z "${LIBSEAT_BACKEND:-}" ] && [ ! -S /run/seatd.sock ]; then
    if command -v seatd >/dev/null 2>&1; then
        echo "mirada-dm: levantando seatd…"
        seatd >/tmp/mirada-seatd.log 2>&1 &
        i=0
        while [ ! -S /run/seatd.sock ] && [ "$i" -lt 25 ]; do
            i=$((i + 1))
            sleep 0.2
        done
        [ -S /run/seatd.sock ] || echo "mirada-dm: seatd no abrió su socket; sigo igual." >&2
    else
        echo "mirada-dm: seatd no está instalado; pruebo el backend que detecte libseat." >&2
        echo "           (instalalo con: pacman -S seatd)" >&2
    fi
fi

export XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/mirada}"
mkdir -p "$XDG_RUNTIME_DIR"
chmod 0711 "$XDG_RUNTIME_DIR"

# El DM corre como root, pero el traspaso baja la sesión al usuario real
# (setuid). Con umask 0 el socket Wayland que crea root queda accesible a
# ese usuario, para que sus clientes (pata, foot…) se conecten.
umask 0

# En DRM la consola queda tapada por el compositor, así que su salida (y la
# de lo que lanza, que hereda estos descriptores) va a un log diagnosticable.
LOG="${MIRADA_LOG:-/tmp/mirada.log}"
echo "mirada-dm: log de la sesión en $LOG"

# Bajo supervisión: si el compositor cae, vuelve (con backoff) y restaura la
# sesión, en vez de devolver la TTY pelada. El postmortem detallado queda en el
# dir de debug del compositor (~/.local/state/mirada o /root/.local/state/mirada
# acá, que corre como root); este `$LOG` guarda el flujo de la sesión.
# `MIRADA_SUPERVISE=0` desactiva. Fallback al exec pelado sin el supervisor.
if command -v mirada-supervise >/dev/null 2>&1; then
    exec mirada-supervise --greeter --drm "$@" >"$LOG" 2>&1
else
    exec mirada-compositor --greeter --drm "$@" >"$LOG" 2>&1
fi
